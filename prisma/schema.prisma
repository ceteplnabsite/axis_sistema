generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  username              String                @unique
  password              String
  name                  String?
  isSuperuser           Boolean               @default(false) @map("is_superuser")
  isStaff               Boolean               @default(false) @map("is_staff")
  isActive              Boolean               @default(true) @map("is_active")
  isApproved            Boolean               @default(false) @map("is_approved")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  lastLogin             DateTime?             @map("last_login")
  isDirecao             Boolean               @default(false) @map("is_direcao")
  isPortalUser          Boolean               @default(false) @map("is_portal_user")
  isAEE                 Boolean               @default(false) @map("is_aee")
  estudanteId           String?               @map("estudante_id")
  auditLogs             AuditLog[]
  deletedMessages       MessageDelete[]
  readMessages          MessageRead[]
  sentMessages          Message[]             @relation("SentMessages")
  notasModificadas      NotaFinal[]           @relation("NotaModificador")
  auditorias            NotaFinalAudit[]
  simuladosLancados     NotaSimulado[]        @relation("SimuladoLancador")
  planosEnsino          PlanoEnsino[]         @relation("ProfessorPlanos")
  provasCriadas         Prova[]               @relation("ProfessorProvas")
  provasSalvas          Prova[]               @relation("ProvasSalvas")
  questoesComFeedback   Questao[]             @relation("AdminFeedback")
  questoes              Questao[]             @relation("ProfessorQuestoes")
  reservasLaboratorio   ReservaLaboratorio[]
  responsavelSimulados  ResponsavelSimulado[]
  ocorrenciasCriadas    Ocorrencia[]          @relation("OcorrenciaAutor")
  estudante             Estudante?            @relation("UserEstudante", fields: [estudanteId], references: [matricula])
  disciplinasPermitidas Disciplina[]          @relation("DisciplinaUsuarios")
  turmasPermitidas      Turma[]               @relation("TurmaUsuarios")
  aeeAcknowledgements   AEEAcknowledgement[]

  @@map("users")
}

model GlobalConfig {
  id                   String   @id @default("global")
  isBancoQuestoesAtivo Boolean  @default(true) @map("is_banco_questoes_ativo")
  anoLetivoAtual       Int      @default(2026) @map("ano_letivo_atual")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("configs")
}

model Message {
  id           String          @id @default(cuid())
  subject      String
  content      String
  category     MessageCategory @default(GERAL)
  senderId     String          @map("sender_id")
  receiverId   String?         @map("receiver_id")
  isRead       Boolean         @default(false) @map("is_read")
  createdAt    DateTime        @default(now()) @map("created_at")
  parentId     String?         @map("parent_id")
  allowReplies Boolean         @default(true) @map("allow_replies")
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at")
  deletedBy    MessageDelete[]
  readBy       MessageRead[]
  parent       Message?        @relation("MessageReplies", fields: [parentId], references: [id])
  replies      Message[]       @relation("MessageReplies")
  sender       User            @relation("SentMessages", fields: [senderId], references: [id])

  @@index([receiverId, createdAt])
  @@index([senderId, createdAt])
  @@index([parentId, createdAt])
  @@index([category, createdAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("messages")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_reads")
}

model MessageDelete {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  deletedAt DateTime @default(now()) @map("deleted_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_deletes")
}

model Questao {
  id              String        @id @default(cuid())
  enunciado       String
  imagemUrl       String?       @map("imagem_url")
  muleta          String?
  alternativaA    String
  alternativaB    String
  alternativaC    String
  alternativaD    String
  alternativaE    String
  correta         String
  dificuldade     Dificuldade   @default(MEDIO)
  status          QuestaoStatus @default(PENDENTE)
  feedbackAdmin   String?       @map("feedback_admin")
  professorId     String        @map("professor_id")
  adminFeedbackId String?       @map("admin_feedback_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  unidade         String?
  adminFeedback   User?         @relation("AdminFeedback", fields: [adminFeedbackId], references: [id])
  professor       User          @relation("ProfessorQuestoes", fields: [professorId], references: [id])
  provas          Prova[]       @relation("ProvaQuestoes")
  disciplinas     Disciplina[]  @relation("QuestaoDisciplinas")
  turmas          Turma[]       @relation("QuestaoTurmas")

  @@map("questoes")
}

model Prova {
  id                 String    @id @default(cuid())
  titulo             String
  turmaId            String?   @map("turma_id")
  professorCriadorId String?   @map("professor_criador_id")
  savedByUserId      String?   @map("saved_by_user_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  observacao         String?
  questoesSnapshot   Json?     @map("questoes_snapshot")
  professorCriador   User?     @relation("ProfessorProvas", fields: [professorCriadorId], references: [id])
  savedByUser        User?     @relation("ProvasSalvas", fields: [savedByUserId], references: [id])
  turma              Turma?    @relation(fields: [turmaId], references: [id])
  questoes           Questao[] @relation("ProvaQuestoes")

  @@map("provas")
}

model Turma {
  id                   String                @id @default(cuid())
  nome                 String
  cursoId              String?               @map("curso_id")
  curso                String?
  turno                String?
  modalidade           String?
  serie                String?
  numero               Int?
  anoLetivo            Int?                  @map("ano_letivo")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  disciplinas          Disciplina[]
  estudantes           Estudante[]
  horarios             HorarioAula[]
  provas               Prova[]
  responsavelSimulados ResponsavelSimulado[]
  planosEnsino         PlanoEnsino[]         @relation("PlanoTurmas")
  questoes             Questao[]             @relation("QuestaoTurmas")
  usuariosPermitidos   User[]                @relation("TurmaUsuarios")

  @@map("turmas")
}

model HorarioAula {
  id         String   @id @default(cuid())
  turmaId    String   @map("turma_id")
  diaSemana  Int      @map("dia_semana")
  horario    Int
  disciplina String
  professor  String?
  updatedAt  DateTime @updatedAt @map("updated_at")
  turma      Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([turmaId, diaSemana, horario])
  @@map("horarios_aula")
}

model Curso {
  id         String   @id @default(cuid())
  nome       String
  sigla      String   @unique
  modalidade String
  turnos     String[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([nome, modalidade])
  @@map("cursos")
}

model Estudante {
  matricula      String         @id
  nome           String
  turmaId        String         @map("turma_id")
  dataNascimento DateTime?      @map("data_nascimento")
  sexo           String?        @map("sexo")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  turma          Turma          @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  notas          NotaFinal[]
  notasSimulado  NotaSimulado[]
  portalAccess   User[]         @relation("UserEstudante")
  ocorrencias    Ocorrencia[]   @relation("OcorrenciaEstudantes")
  aeeProfile     AEEProfile?    @relation("EstudanteAEE")
  teamMembers    TeamMember[]

  @@map("estudantes")
}

model Ocorrencia {
  id           String      @id @default(cuid())
  titulo       String
  descricao    String      @db.Text
  tipo         String      // Ex: Comportamental, Médica, Pedagógica, Elogio, etc.
  data         DateTime    @default(now())
  registradoPorId String   @map("registrado_por_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  
  estudantes   Estudante[] @relation("OcorrenciaEstudantes")
  autor        User        @relation("OcorrenciaAutor", fields: [registradoPorId], references: [id])

  @@index([data])
  @@map("ocorrencias")
}

model Disciplina {
  id                 String            @id @default(cuid())
  nome               String
  turmaId            String            @map("turma_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  areaId             String?           @map("area_id")
  area               AreaConhecimento? @relation(fields: [areaId], references: [id])
  turma              Turma             @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  notas              NotaFinal[]
  usuariosPermitidos User[]            @relation("DisciplinaUsuarios")
  questoes           Questao[]         @relation("QuestaoDisciplinas")

  @@map("disciplinas")
}

model NotaFinal {
  id                String           @id @default(cuid())
  estudanteId       String           @map("estudante_id")
  disciplinaId      String           @map("disciplina_id")
  nota              Float
  notaRecuperacao   Float?           @map("nota_recuperacao")
  status            StatusNota
  modifiedById      String?          @map("modified_by_id")
  modifiedAt        DateTime         @default(now()) @map("modified_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  nota1             Float?           @map("nota_1")
  nota2             Float?           @map("nota_2")
  nota3             Float?           @map("nota_3")
  isDesistenteUnid1 Boolean          @default(false) @map("is_desistente_unid1")
  isDesistenteUnid2 Boolean          @default(false) @map("is_desistente_unid2")
  isDesistenteUnid3 Boolean          @default(false) @map("is_desistente_unid3")
  disciplina        Disciplina       @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  estudante         Estudante        @relation(fields: [estudanteId], references: [matricula], onDelete: Cascade)
  modifiedBy        User?            @relation("NotaModificador", fields: [modifiedById], references: [id])
  auditorias        NotaFinalAudit[]

  @@unique([estudanteId, disciplinaId])
  @@map("notas_finais")
}

model NotaFinalAudit {
  id           String     @id @default(cuid())
  notaFinalId  String     @map("nota_final_id")
  notaAnterior Float?     @map("nota_anterior")
  notaAtual    Float      @map("nota_atual")
  status       StatusNota
  modifiedById String?    @map("modified_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  modifiedBy   User?      @relation(fields: [modifiedById], references: [id])
  notaFinal    NotaFinal  @relation(fields: [notaFinalId], references: [id], onDelete: Cascade)

  @@map("notas_finais_audit")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  details    String?
  ipAddress  String?  @map("ip_address")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model PlanoEnsino {
  id             String   @id @default(cuid())
  disciplinaNome String   @map("disciplina_nome")
  periodoInicio  DateTime @map("periodo_inicio")
  periodoFim     DateTime @map("periodo_fim")
  indicadores    String
  conteudos      String
  metodologias   String
  recursos       String
  avaliacao      String
  observacoes    String?
  professorId    String   @map("professor_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  professor      User     @relation("ProfessorPlanos", fields: [professorId], references: [id])
  turmas         Turma[]  @relation("PlanoTurmas")

  @@map("planos_ensino")
}

model AreaConhecimento {
  id           String                @id @default(cuid())
  nome         String                @unique
  disciplinas  Disciplina[]
  matrices     MatrizCurricular[]
  notas        NotaSimulado[]
  responsaveis ResponsavelSimulado[]

  @@map("areas_conhecimento")
}

model NotaSimulado {
  id          String           @id @default(cuid())
  estudanteId String           @map("estudante_id")
  areaId      String           @map("area_id")
  unidade     Int
  nota        Float
  anoLetivo   Int              @default(2026) @map("ano_letivo")
  lancadoById String           @map("lancado_by_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  area        AreaConhecimento @relation(fields: [areaId], references: [id])
  estudante   Estudante        @relation(fields: [estudanteId], references: [matricula], onDelete: Cascade)
  lancadoBy   User             @relation("SimuladoLancador", fields: [lancadoById], references: [id])

  @@unique([estudanteId, areaId, unidade, anoLetivo])
  @@map("notas_simulados")
}

model MatrizCurricular {
  id        String            @id @default(cuid())
  nome      String
  cursoId   String            @map("curso_id")
  serie     String
  areaId    String?           @map("area_id")
  anoLetivo Int               @default(2026) @map("ano_letivo")
  area      AreaConhecimento? @relation(fields: [areaId], references: [id])

  @@unique([nome, cursoId, serie, anoLetivo])
  @@map("matrizes_curriculares")
}

model ResponsavelSimulado {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  turmaId   String           @map("turma_id")
  areaId    String           @map("area_id")
  anoLetivo Int              @default(2026) @map("ano_letivo")
  createdAt DateTime         @default(now()) @map("created_at")
  area      AreaConhecimento @relation(fields: [areaId], references: [id], onDelete: Cascade)
  turma     Turma            @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([turmaId, areaId, anoLetivo])
  @@map("responsaveis_simulados")
}

model Laboratorio {
  id        String               @id @default(cuid())
  nome      String               @unique
  descricao String?
  reservas  ReservaLaboratorio[]

  @@map("laboratorios")
}

model ReservaLaboratorio {
  id            String      @id @default(cuid())
  laboratorioId String      @map("laboratorio_id")
  userId        String      @map("user_id")
  data          DateTime
  turno         String
  horario       Int
  disciplina    String?
  turmaId       String?     @map("turma_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  laboratorio   Laboratorio @relation(fields: [laboratorioId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([laboratorioId, data, turno, horario])
  @@map("reservas_laboratorio")
}

enum MessageCategory {
  COMUNICADO
  SUPORTE
  DIRECAO
  GERAL
}

enum QuestaoStatus {
  PENDENTE
  APROVADA
  REJEITADA
}

enum Dificuldade {
  FACIL
  MEDIO
  DIFICIL
}

enum StatusNota {
  APROVADO
  RECUPERACAO
  DESISTENTE
  APROVADO_RECUPERACAO
  APROVADO_CONSELHO
  DEPENDENCIA
  CONSERVADO

  @@map("status_nota")
}

model AEEProfile {
  id                String    @id @default(cuid())
  estudanteId       String    @unique @map("estudante_id")
  cids              String[]  // Array de códigos CID-10
  condicao          String    @db.Text
  recomendacoes     String    @db.Text
  notasDirecao      String?   @db.Text
  contatoNome       String?   @map("contato_nome")
  contatoTelefone   String?   @map("contato_telefone")
  fotoUrl           String?   @db.Text @map("foto_url") // Campo para foto do aluno (Base64)
  
  // Novas flags para acompanhamento pedagógico
  precisaProvaAdaptada     Boolean   @default(false) @map("precisa_prova_adaptada")
  precisaProvaSalaEspecial Boolean   @default(false) @map("precisa_prova_sala_especial")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  estudante         Estudante @relation("EstudanteAEE", fields: [estudanteId], references: [matricula], onDelete: Cascade)
  acknowledgements  AEEAcknowledgement[]

  @@map("aee_profiles")
}

model AEEAcknowledgement {
  id           String     @id @default(cuid())
  profileId    String     @map("profile_id")
  userId       String     @map("user_id")
  readAt       DateTime   @default(now()) @map("read_at")
  
  profile      AEEProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, userId])
  @@map("aee_acknowledgements")
}

model SportsSettings {
  id                    String   @id @default("global_config")
  minGrade              Float    @default(6.0) @map("min_grade")
  minAttendance         Float    @default(75.0) @map("min_attendance")
  maxInfrequentPercent  Float    @default(20.0) @map("max_infrequent_percent")
  termsContent          String   @default("") @map("terms_content") @db.Text
  isOpen                Boolean  @default(true) @map("is_open")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("sports_settings")
}

model SportModality {
  id          String       @id @default(cuid())
  nome        String       @unique
  minPlayers  Int          @default(5) @map("min_players")
  maxPlayers  Int          @default(12) @map("max_players")
  isActive    Boolean      @default(true) @map("is_active")
  isMisto     Boolean      @default(false) @map("is_misto")
  teams       SportsTeam[]
  matches     GameMatch[]

  @@map("sport_modalities")
}

model SportsTeam {
  id           String       @id @default(cuid())
  nome         String       // Nome do time (Ex: Os Devs)
  contactEmail String       @map("contact_email")
  contactPhone String?      @map("contact_phone")
  modalityId   String       @map("modality_id")
  status       String       @default("Pendente")
  feedback     String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  modality     SportModality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  matches1     GameMatch[]  @relation("Team1")
  matches2     GameMatch[]  @relation("Team2")
  wins         GameMatch[]  @relation("Winner")

  @@map("sports_teams")
}

model TeamMember {
  id           String     @id @default(cuid())
  teamId       String     @map("team_id")
  studentId    String     @map("student_id")
  isLeader     Boolean    @default(false) @map("is_leader")
  idFrontUrl   String?    @map("id_front_url")
  idBackUrl    String?    @map("id_back_url")
  team         SportsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  student      Estudante  @relation(fields: [studentId], references: [matricula], onDelete: Cascade)

  @@unique([teamId, studentId])
  @@map("sports_team_members")
}

model GameMatch {
  id           String        @id @default(cuid())
  team1Id      String?       @map("team1_id")
  team2Id      String?       @map("team2_id")
  modalityId   String        @map("modality_id")
  round        Int           @default(1)
  score1       Int           @default(0)
  score2       Int           @default(0)
  winnerId     String?       @map("winner_id")
  matchDate    DateTime?     @map("match_date")
  status       String        @default("PENDIENTE") // PENDING, ONGOING, COMPLETED
  
  modality     SportModality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  team1        SportsTeam?   @relation("Team1", fields: [team1Id], references: [id], onDelete: SetNull)
  team2        SportsTeam?   @relation("Team2", fields: [team2Id], references: [id], onDelete: SetNull)
  winner       SportsTeam?   @relation("Winner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@map("game_matches")
}
